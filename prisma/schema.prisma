generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id                String                 @id @default(uuid())
  firstName         String
  secondName        String
  visitsTotal       Int                    @default(0)
  visitsUsed        Int                    @default(0)
  cards             Card[]
  answers           MemberQuestionAnswer[]
  pushSubscriptions PushSubscription[]
  notifications     MemberNotification[]
  trainingOptOuts   TrainingOptOut[]

  @@map("members")
}

model Card {
  id        String   @id @default(uuid())
  cardCode  String   @unique
  member    Member   @relation(fields: [memberId], references: [id])
  memberId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("cards")
}

model Question {
  id        String                 @id @default(uuid())
  text      String
  isActive  Boolean                @default(true)
  answers   MemberQuestionAnswer[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@map("questions")
}

model MemberQuestionAnswer {
  id         String   @id @default(uuid())
  memberId   String
  questionId String
  answer     String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([memberId, questionId])
  @@map("member_question_answers")
}

model PushSubscription {
  id        String   @id @default(uuid())
  memberId  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  device    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, isActive])
  @@map("push_subscriptions")
}

model MemberNotification {
  id       String    @id @default(uuid())
  memberId String
  type     String
  title    String
  body     String
  url      String?
  sentAt   DateTime  @default(now())
  readAt   DateTime?
  member   Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, sentAt])
  @@index([memberId, readAt])
  @@map("member_notifications")
}

enum MediaFileStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

model MediaFile {
  id           String          @id @default(uuid())
  originalName String
  displayName  String
  diskFileName String          @unique
  mimeType     String
  sizeBytes    BigInt
  status       MediaFileStatus @default(UPLOADING)
  isVisible    Boolean         @default(true)
  durationSecs Int?
  uploadId     String?         @unique
  errorMessage       String?
  cloudinaryPublicId String?
  cloudinaryUrl      String?
  createdAt          DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  folderItems FolderItem[]
  shareItems  ShareLinkItem[]
  auditLogs   AuditLog[]      @relation("MediaFileAuditLogs")

  @@index([status])
  @@index([createdAt])
  @@index([isVisible])
  @@map("media_files")
}

model Folder {
  id        String       @id @default(uuid())
  name      String
  parentId  String?
  parent    Folder?      @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]     @relation("FolderTree")
  items     FolderItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([parentId])
  @@map("folders")
}

model FolderItem {
  id          String    @id @default(uuid())
  folderId    String
  mediaFileId String
  displayName String?
  sortOrder   Int       @default(0)
  folder      Folder    @relation(fields: [folderId], references: [id], onDelete: Cascade)
  mediaFile   MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([folderId, mediaFileId])
  @@index([folderId, sortOrder])
  @@map("folder_items")
}

model ShareLink {
  id           String          @id @default(uuid())
  token        String          @unique
  name         String?
  expiresAt    DateTime
  createdAt    DateTime        @default(now())
  accessCount  Int             @default(0)
  lastAccessAt DateTime?
  items        ShareLinkItem[]

  @@index([token])
  @@index([expiresAt])
  @@map("share_links")
}

model ShareLinkItem {
  id          String    @id @default(uuid())
  shareLinkId String
  mediaFileId String
  sortOrder   Int       @default(0)
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  mediaFile   MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)

  @@unique([shareLinkId, mediaFileId])
  @@index([shareLinkId, sortOrder])
  @@map("share_link_items")
}

model AuditLog {
  id          String     @id @default(uuid())
  action      String
  entityType  String
  entityId    String?
  details     String?
  mediaFileId String?
  mediaFile   MediaFile? @relation("MediaFileAuditLogs", fields: [mediaFileId], references: [id], onDelete: SetNull)
  ipAddress   String?
  createdAt   DateTime   @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model AdminPushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  device    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("admin_push_subscriptions")
}

model TrainingSchedule {
  id                 String   @id @default(uuid())
  trainingWeekdays   Int[]
  trainingTime       String?
  trainingWindowDays Int      @default(30)
  isActive           Boolean  @default(true)
  timeMode           String   @default("single")
  trainingDates      String[]
  trainingDateTimes  Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("training_schedules")
}

model TrainingOptOut {
  id           String   @id @default(uuid())
  memberId     String
  trainingDate DateTime @db.Date
  reasonCode   String?
  reasonText   String?
  createdAt    DateTime @default(now())
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, trainingDate])
  @@index([trainingDate])
  @@map("training_opt_outs")
}

model TrainingNote {
  id           String   @id @default(uuid())
  trainingDate DateTime @db.Date @unique
  note         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("training_notes")
}
